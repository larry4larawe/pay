{
  "name": "tad-pay",
  "version": "1.1.0",
  "description": "Générateur de bulletins de paie — TAD IT CONSULTING",
  "main": "electron/main.js",
  "scripts": {
    "start": "webpack --config webpack.config.js && electron .",
    "dev": "concurrently \"webpack --watch\" \"electron .\"",
    "build": "webpack --config webpack.config.js --mode production",
    "pack": "electron-builder --mac",
    "dist": "npm run build && electron-builder --mac --publish=never"
  },
  "build": {
    "appId": "com.tad.pay",
    "productName": "TAD Pay",
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "assets/logo.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/index.html",
      "dist/renderer.js",
      "electron/**/*",
      "assets/**/*",
      "src/utils/**/*",
      "data/**/*",
      "node_modules/docx/**/*"
    ]
  },
  "dependencies": {
    "docx": "^8.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.0",
    "electron": "^42.4.1",
    "electron-builder": "^24.9.0",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^3.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}
